{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "scraper",
	"main": "src/index.ts",
	"compatibility_date": "2026-05-25",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"placement": {
    "mode": "smart"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "king-db",
      "database_id": "4314a9ec-3979-4ca8-b701-08116949484c"
    }
  ]
}
